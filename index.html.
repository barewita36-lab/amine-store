<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AMINE Store - PS4</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root{--gold:#FFD700;--blue:#00BFFF;--dark:#0d0d1a;--dark-light:#1a1a2e;--red:#e74c3c;--green:#27ae60}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Cairo',sans-serif;background:var(--dark);color:#fff;overflow-x:hidden}

/* Loading */
.load{position:fixed;top:0;left:0;width:100%;height:100%;background:var(--dark);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;transition:opacity .5s}
.load.hide{opacity:0;pointer-events:none}
.spin{width:50px;height:50px;border:3px solid rgba(255,215,0,.1);border-top-color:var(--gold);border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* Header */
.header{background:linear-gradient(135deg,var(--dark-light),var(--dark));padding:15px 0;position:fixed;width:100%;top:0;z-index:1000;border-bottom:2px solid var(--gold)}
.container{max-width:1200px;margin:0 auto;padding:0 20px;display:flex;justify-content:space-between;align-items:center}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.logo-icon{width:40px;height:40px;background:var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--dark);font-size:18px}
.logo-text{font-size:24px;font-weight:900;color:var(--gold)}
.logo-sub{font-size:10px;color:var(--blue);letter-spacing:2px}
.nav{display:flex;gap:25px;list-style:none}
.nav a{color:#fff;text-decoration:none;font-weight:600;transition:.3s}
.nav a:hover{color:var(--gold)}
.header-actions{display:flex;align-items:center;gap:15px}
.cart-btn{position:relative;background:none;border:2px solid var(--gold);color:var(--gold);width:40px;height:40px;border-radius:50%;cursor:pointer;font-size:16px;transition:.3s}
.cart-btn:hover{background:var(--gold);color:var(--dark)}
.cart-count{position:absolute;top:-5px;right:-5px;background:var(--red);color:#fff;font-size:11px;width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700}
.theme-btn{background:none;border:2px solid var(--gold);color:var(--gold);width:35px;height:35px;border-radius:50%;cursor:pointer}

/* Announcement Bar */
.announcement{background:linear-gradient(90deg,var(--gold),#ffaa00);color:var(--dark);text-align:center;padding:8px;font-size:14px;font-weight:700;position:fixed;top:68px;width:100%;z-index:999;animation:slideDown .5s ease}
@keyframes slideDown{from{transform:translateY(-100%)}to{transform:translateY(0)}}

/* Hero */
.hero{margin-top:110px;padding:80px 20px 60px;text-align:center;background:linear-gradient(135deg,var(--dark),var(--dark-light));position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-50%;right:-20%;width:500px;height:500px;background:radial-gradient(circle,rgba(255,215,0,.1),transparent 70%);border-radius:50%}
.badge{display:inline-block;background:var(--gold);color:var(--dark);padding:5px 15px;border-radius:20px;font-weight:700;font-size:12px;margin-bottom:15px}
.hero h1{font-size:52px;font-weight:900;color:var(--gold);margin-bottom:10px}
.hero p{color:#888;font-size:18px;margin-bottom:25px}
.hero-stats{display:flex;justify-content:center;gap:40px;margin-top:30px;flex-wrap:wrap}
.stat{text-align:center}
.stat-num{font-size:32px;font-weight:900;color:var(--gold)}
.stat-label{font-size:14px;color:#888}

/* Ticker */
.ticker{background:var(--dark-light);padding:12px 0;overflow:hidden;border-top:1px solid rgba(255,215,0,.1);border-bottom:1px solid rgba(255,215,0,.1)}
.ticker-track{display:flex;gap:40px;animation:ticker 20s linear infinite;white-space:nowrap}
.ticker-item{display:flex;align-items:center;gap:8px;color:#ccc;font-size:14px}
.ticker-item i{color:var(--gold)}
@keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* Section Title */
.section-title{text-align:center;padding:50px 20px 20px}
.section-title h2{font-size:32px;color:var(--gold);margin-bottom:8px}
.section-title p{color:#888;font-size:16px}

/* Product Gallery */
.gallery-section{padding:20px;max-width:900px;margin:0 auto}
.gallery-main{position:relative;background:var(--dark-light);border-radius:20px;overflow:hidden;border:1px solid rgba(255,215,0,.1);margin-bottom:15px}
.gallery-main img{width:100%;height:350px;object-fit:contain;background:radial-gradient(circle at center,rgba(255,215,0,.05),transparent 70%);padding:20px}
.gallery-thumbs{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.thumb{width:80px;height:60px;border-radius:10px;border:2px solid transparent;cursor:pointer;overflow:hidden;transition:.3s;object-fit:cover;background:var(--dark-light)}
.thumb:hover,.thumb.active{border-color:var(--gold)}

/* Product Detail */
.product-detail{padding:30px 20px;max-width:800px;margin:0 auto}
.product-detail-card{background:var(--dark-light);border-radius:20px;padding:30px;border:1px solid rgba(255,215,0,.1)}
.product-name{font-size:28px;font-weight:700;margin-bottom:10px}
.rating{color:var(--gold);margin-bottom:15px}
.price-box{margin-bottom:20px;display:flex;align-items:center;gap:15px;flex-wrap:wrap}
.price{font-size:36px;font-weight:900;color:var(--gold)}
.old-price{text-decoration:line-through;color:#888;font-size:20px}
.discount{background:var(--red);color:#fff;padding:5px 12px;border-radius:15px;font-size:12px;font-weight:700}
.stock-status{display:flex;align-items:center;gap:8px;color:var(--green);font-size:14px;margin-bottom:20px}
.stock-status i{animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}

/* Specs */
.specs{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin:20px 0}
.spec{background:var(--dark);padding:12px 15px;border-radius:10px;border:1px solid rgba(255,215,0,.1);display:flex;align-items:center;gap:10px}
.spec i{color:var(--gold);width:20px}
.spec span{font-size:13px;color:#ccc}

/* Features */
.features{display:grid;grid-template-columns:repeat(4,1fr);gap:15px;margin:20px 0}
.feature{background:var(--dark);padding:20px 15px;border-radius:10px;border:1px solid rgba(255,215,0,.1);text-align:center;transition:.3s}
.feature:hover{border-color:var(--gold);transform:translateY(-3px)}
.feature i{color:var(--gold);font-size:24px;margin-bottom:8px}
.feature-text{font-size:13px;color:#ccc}

/* Buttons */
.btn-group{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:25px}
.btn-primary{background:var(--gold);color:var(--dark);padding:15px 40px;border:none;border-radius:30px;font-weight:700;font-size:16px;cursor:pointer;transition:.3s;display:flex;align-items:center;gap:8px}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 10px 30px rgba(255,215,0,.3)}
.btn-secondary{background:transparent;color:var(--blue);padding:15px 40px;border:2px solid var(--blue);border-radius:30px;text-decoration:none;font-weight:700;transition:.3s;display:flex;align-items:center;gap:8px}
.btn-secondary:hover{background:var(--blue);color:var(--dark)}
.btn-cart{background:var(--green);color:#fff;padding:15px 30px;border:none;border-radius:30px;font-weight:700;font-size:16px;cursor:pointer;transition:.3s;display:flex;align-items:center;gap:8px}
.btn-cart:hover{transform:translateY(-3px);box-shadow:0 10px 30px rgba(39,174,96,.3)}

/* More Products */
.products-grid{padding:20px;max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:25px}
.product-card{background:var(--dark-light);border-radius:20px;padding:20px;border:1px solid rgba(255,215,0,.1);text-align:center;transition:.3s;position:relative;overflow:hidden}
.product-card:hover{border-color:var(--gold);transform:translateY(-5px)}
.product-card .tag{position:absolute;top:15px;right:15px;background:var(--red);color:#fff;padding:3px 10px;border-radius:10px;font-size:11px;font-weight:700}
.product-card .tag.new{background:var(--green)}
.product-card .tag.hot{background:var(--gold);color:var(--dark)}
.product-card img{width:100%;height:180px;object-fit:contain;margin-bottom:15px;background:radial-gradient(circle at center,rgba(255,215,0,.05),transparent 70%);border-radius:10px;padding:10px}
.product-card h3{font-size:18px;margin-bottom:8px}
.product-card .card-price{font-size:24px;font-weight:900;color:var(--gold);margin-bottom:10px}
.product-card .card-old{font-size:14px;color:#888;text-decoration:line-through;margin-left:8px}
.product-card .card-btns{display:flex;gap:8px;justify-content:center}
.product-card .card-btn{padding:8px 20px;border-radius:20px;font-size:13px;font-weight:700;cursor:pointer;border:none;transition:.3s}
.product-card .card-btn-buy{background:var(--gold);color:var(--dark)}
.product-card .card-btn-wa{background:transparent;color:var(--blue);border:1px solid var(--blue)}
.product-card .card-btn-wa:hover{background:var(--blue);color:var(--dark)}

/* Reviews */
.reviews-section{padding:20px;max-width:800px;margin:0 auto}
.reviews-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:20px}
.review-card{background:var(--dark-light);border-radius:15px;padding:20px;border:1px solid rgba(255,215,0,.1)}
.review-header{display:flex;align-items:center;gap:12px;margin-bottom:12px}
.review-avatar{width:45px;height:45px;background:var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--dark);font-weight:900;font-size:18px}
.review-name{font-weight:700}
.review-date{font-size:12px;color:#888}
.review-stars{color:var(--gold);margin-bottom:10px;font-size:13px}
.review-text{font-size:14px;color:#ccc;line-height:1.6}

/* Trust Badges */
.trust-section{padding:40px 20px;background:var(--dark-light);text-align:center}
.trust-badges{display:flex;justify-content:center;gap:40px;flex-wrap:wrap;margin-top:20px}
.trust-badge{display:flex;flex-direction:column;align-items:center;gap:8px}
.trust-badge i{font-size:30px;color:var(--gold)}
.trust-badge span{font-size:13px;color:#ccc}

/* Contact */
.contact{padding:40px 20px;background:var(--dark-light);text-align:center}
.contact h2{color:var(--gold);margin-bottom:20px}
.contact-info{display:flex;justify-content:center;gap:30px;flex-wrap:wrap}
.contact-item{display:flex;align-items:center;gap:10px;background:var(--dark);padding:12px 20px;border-radius:10px;border:1px solid rgba(255,215,0,.1);transition:.3s}
.contact-item:hover{border-color:var(--gold)}
.contact-item i{color:var(--gold)}
.contact-item a{color:#fff;text-decoration:none;font-size:14px}

/* Footer */
.footer{padding:25px 20px;text-align:center;color:#888;font-size:14px;border-top:1px solid rgba(255,215,0,.1)}
.footer-social{display:flex;justify-content:center;gap:15px;margin-bottom:15px}
.footer-social a{width:40px;height:40px;border-radius:50%;border:1px solid rgba(255,215,0,.2);display:flex;align-items:center;justify-content:center;color:var(--gold);text-decoration:none;transition:.3s}
.footer-social a:hover{background:var(--gold);color:var(--dark)}

/* Quick WhatsApp */
.quick-wa{position:fixed;bottom:20px;right:20px;background:#25D366;color:#fff;width:55px;height:55px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24px;text-decoration:none;box-shadow:0 5px 20px rgba(37,211,102,.4);animation:float 3s ease-in-out infinite;z-index:100}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}

/* Visitor */
.visitor{position:fixed;bottom:20px;left:20px;background:var(--dark-light);padding:8px 15px;border-radius:20px;border:1px solid rgba(255,215,0,.2);font-size:13px;display:flex;align-items:center;gap:8px;z-index:100}
.visitor i{color:var(--gold)}
.dot{width:8px;height:8px;background:var(--green);border-radius:50%;animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* Toast Notification */
.toast{position:fixed;top:100px;left:50%;transform:translateX(-50%) translateY(-100px);background:var(--green);color:#fff;padding:12px 25px;border-radius:30px;font-weight:700;font-size:14px;z-index:10000;opacity:0;transition:.4s;box-shadow:0 5px 20px rgba(39,174,96,.3);display:flex;align-items:center;gap:8px}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* Cart Modal */
.cart-modal{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.7);z-index:10001;display:none;align-items:center;justify-content:center}
.cart-modal.show{display:flex}
.cart-content{background:var(--dark-light);border-radius:20px;padding:30px;max-width:500px;width:90%;max-height:80vh;overflow-y:auto;border:1px solid rgba(255,215,0,.2)}
.cart-content h3{color:var(--gold);margin-bottom:20px;font-size:22px;text-align:center}
.cart-item{display:flex;align-items:center;gap:15px;padding:15px;background:var(--dark);border-radius:10px;margin-bottom:10px}
.cart-item img{width:60px;height:60px;object-fit:contain;border-radius:8px;background:rgba(255,215,0,.05)}
.cart-item-info{flex:1}
.cart-item-name{font-weight:700;font-size:14px}
.cart-item-price{color:var(--gold);font-size:14px}
.cart-item-remove{background:none;border:none;color:var(--red);cursor:pointer;font-size:16px}
.cart-total{text-align:center;margin:20px 0;padding-top:15px;border-top:1px solid rgba(255,215,0,.1)}
.cart-total span{font-size:24px;font-weight:900;color:var(--gold)}
.cart-actions{display:flex;gap:10px;justify-content:center}
.cart-close{background:none;border:1px solid #888;color:#888;padding:10px 25px;border-radius:20px;cursor:pointer}
.cart-checkout{background:var(--gold);color:var(--dark);border:none;padding:10px 25px;border-radius:20px;font-weight:700;cursor:pointer}

/* Responsive */
@media(max-width:768px){
.nav{display:none}
.hero h1{font-size:36px}
.hero-stats{gap:20px}
.features{grid-template-columns:repeat(2,1fr)}
.specs{grid-template-columns:1fr}
.products-grid{grid-template-columns:1fr}
.reviews-grid{grid-template-columns:1fr}
}
</style>
</head>
