<script>
// Hide loading
setTimeout(()=>document.getElementById('load').classList.add('hide'),1500);

// Visitor counter
let v=Math.floor(Math.random()*30)+12;
document.getElementById('visitors').textContent=v;
setInterval(()=>{v+=Math.floor(Math.random()*3)-1;if(v<5)v=5;if(v>50)v=50;document.getElementById('visitors').textContent=v},8000);

// Theme toggle
function toggleTheme(){
var b=document.body,t=document.getElementById('themeBtn');
if(b.getAttribute('data-theme')==='light'){b.setAttribute('data-theme','dark');t.innerHTML='<i class="fas fa-moon"></i>'}
else{b.setAttribute('data-theme','light');t.innerHTML='<i class="fas fa-sun"></i>'}
}

// Gallery
function changeImg(el){
document.querySelectorAll('.thumb').forEach(t=>t.classList.remove('active'));
el.classList.add('active');
document.getElementById('mainImg').src=el.src;
}

// Cart System
let cart=[];
function addToCart(name, price, img){
cart.push({name, price, img});
updateCart();
showToast('تمت إضافة '+name+' إلى السلة!');
}
function updateCart(){
document.getElementById('cartCount').textContent=cart.length;
let html='';
let total=0;
cart.forEach((item,i)=>{
total+=item.price;
html+='<div class="cart-item"><img src="'+item.img+'"><div class="cart-item-info"><div class="cart-item-name">'+item.name+'</div><div class="cart-item-price">'+item.price.toLocaleString()+' دج</div></div><button class="cart-item-remove" onclick="removeFromCart('+i+')"><i class="fas fa-trash"></i></button></div>';
});
if(cart.length===0)html='<p style="text-align:center;color:#888;padding:20px">السلة فارغة</p>';
document.getElementById('cartItems').innerHTML=html;
document.getElementById('cartTotal').textContent=total.toLocaleString()+' دج';
}
function removeFromCart(i){
cart.splice(i,1);
updateCart();
}
function openCart(){
document.getElementById('cartModal').classList.add('show');
}
function closeCart(e){
if(!e||e.target.id==='cartModal')document.getElementById('cartModal').classList.remove('show');
}
function checkout(){
if(cart.length===0){showToast('السلة فارغة!');return;}
let msg='مرحباً AMINE Store، أريد طلب:\n';
let total=0;
cart.forEach(item=>{msg+='- '+item.name+': '+item.price.toLocaleString()+' دج\n';total+=item.price;});
msg+='\nالإجمالي: '+total.toLocaleString()+' دج';
window.open('https://wa.me/213551426472?text='+encodeURIComponent(msg),'_blank');
}

// Toast
function showToast(msg){
const t=document.getElementById('toast');
document.getElementById('toastMsg').textContent=msg;
t.classList.add('show');
setTimeout(()=>t.classList.remove('show'),2500);
}

// Order Now
function orderNow(name, price){
var msg=encodeURIComponent('مرحباً AMINE Store، أريد طلب '+name+' بسعر '+price.toLocaleString()+' دج');
window.open('https://wa.me/213551426472?text='+msg,'_blank');
}

// Announcement rotation
const announcements=[
'🔥 عرض خاص: خصم على جميع المنتجات حتى نهاية الأسبوع!',
'🚚 توصيل لجميع مناطق بجاية',
'🎁 اشترِ PS4 واحصل على يد تحكم بخصم 50%',
'⭐ تقييم 4.8/5 من أكثر من 500 عميل'
];
let annIdx=0;
setInterval(()=>{
annIdx=(annIdx+1)%announcements.length;
document.getElementById('announcement').innerHTML='<i class="fas fa-bullhorn"></i> '+announcements[annIdx];
},6000);
</script>
